{
  "name": "pop-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=@pop/api",
    "dev:web": "npm run dev --workspace=@pop/web",
    "build:api": "npm run build --workspace=@pop/api",
    "build:web": "npm run build --workspace=@pop/web",
    "build:shared": "npm run build --workspace=@pop/shared-types",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  }
}
