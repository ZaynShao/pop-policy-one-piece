# ==========================================
# POP 本地开发环境变量样板
# 复制为 .env 后使用:cp .env.example .env
# 本文件可进 git;.env 严禁进 git
# ==========================================

# --- API ---
NODE_ENV=development
PORT=3001

# --- Postgres(docker-compose 默认值) ---
DATABASE_URL=postgresql://pop:pop_dev_password@localhost:5432/pop

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- MinIO(S3 兼容) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=pop
MINIO_SECRET_KEY=pop_dev_password
MINIO_BUCKET=pop

# --- JWT(V0.2 加认证后再用) ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
